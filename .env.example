# Shad Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Redis Configuration (required)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Obsidian Local REST API (optional - for vault integration)
# Install: https://github.com/coddingtonbear/obsidian-local-rest-api
# =============================================================================
OBSIDIAN_API_KEY=your_obsidian_api_key_here
OBSIDIAN_BASE_URL=https://127.0.0.1:27124
OBSIDIAN_VERIFY_SSL=false
OBSIDIAN_VAULT_PATH=/path/to/your/vault

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# =============================================================================
# Budget Defaults (optional)
# =============================================================================
DEFAULT_MAX_DEPTH=3
DEFAULT_MAX_NODES=50
DEFAULT_MAX_WALL_TIME=300
DEFAULT_MAX_TOKENS=100000

# =============================================================================
# Path Configuration (optional - for local development)
# =============================================================================
HISTORY_PATH=./History
SKILLS_PATH=./Skills
CORE_PATH=./CORE

# =============================================================================
# LLM Provider Configuration
# =============================================================================
# Provider routing for RLM calls. Supported values:
#   auto               Prefer Gemini CLI for gemini-* models, Claude Code for
#                      claude-/Ollama models, then API/OpenAI-compatible fallback.
#   claude-code        Force Claude Code CLI.
#   gemini-cli         Force Gemini CLI.
#   anthropic          Force Anthropic API.
#   openai             Force OpenAI API.
#   openai-compatible  Use an OpenAI-compatible endpoint/provider router.
#   edwin-gateway      Use EdwinPAI's OpenAI-compatible gateway/provider router.
SHAD_LLM_PROVIDER=auto

# Direct provider/API-compatible credentials.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
SHAD_OPENAI_BASE_URL=
SHAD_OPENAI_ORGANIZATION=

# EdwinPAI gateway/provider-router mode. Desktop should set these when Shad is
# configured as an EdwinPAI deep-reasoning worker.
SHAD_EDWIN_GATEWAY_BASE_URL=http://127.0.0.1:18789/v1
SHAD_EDWIN_GATEWAY_API_KEY=

# Per-tier model selection. These can be EdwinPAI model ids when using
# SHAD_LLM_PROVIDER=openai-compatible or edwin-gateway.
SHAD_ORCHESTRATOR_MODEL=claude-opus-4-6
SHAD_WORKER_MODEL=claude-sonnet-4-6
SHAD_LEAF_MODEL=claude-sonnet-4-6
SHAD_LLM_MAX_CONCURRENT=4
